---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page not found · Elmar Ismayil">
  <div class="flex min-h-screen flex-col items-center justify-center bg-white px-6 text-center">
    <p class="text-base font-semibold text-brand">404</p>
    <h1 class="mt-4 text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">
      Page not found
    </h1>
    <p class="mt-6 text-lg leading-8 text-gray-600">
      Sorry, we couldn't find the page you're looking for.
    </p>
    <a
      href="/"
      class="mt-10 text-sm font-semibold leading-6 text-gray-900 hover:text-brand"
    >
      <span aria-hidden="true">&larr;</span> Back home
    </a>
  </div>
</Layout>
