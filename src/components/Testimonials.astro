---
// NOTE: Placeholder testimonials — replace with real client quotes & names before going live.
const quotes = [
  {
    quote:
      "Elmar took our half-finished app and got it to launch in weeks. He's the rare developer who actually communicates and just makes things work.",
    name: "Founder",
    role: "Early-stage SaaS startup",
  },
  {
    quote:
      "Clear scope, no surprises, and the quality was excellent. He explained trade-offs in a way our non-technical team could follow.",
    name: "Product Lead",
    role: "E-commerce company",
  },
  {
    quote:
      "We came to him with a tangled legacy system. He stabilised it and gave us a roadmap we could actually trust. Worth every penny.",
    name: "Operations Manager",
    role: "Logistics business",
  },
];
---

<section class="py-24 sm:py-28">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <p class="reveal text-[13px] font-semibold uppercase tracking-[0.18em] text-brand">
        Testimonials
      </p>
      <h2 class="reveal mt-3 text-3xl font-extrabold tracking-tight text-ink sm:text-[2.6rem] sm:leading-[1.1]" style="transition-delay:60ms">
        Trusted to get it done
      </h2>
    </div>

    <div class="mt-14 grid gap-5 lg:grid-cols-3">
      {
        quotes.map((q, i) => (
          <figure
            class="reveal flex flex-col rounded-2xl border border-line bg-paper p-7"
            style={`transition-delay:${i * 70}ms`}
          >
            <div class="flex gap-0.5 text-brand">
              {Array.from({ length: 5 }).map(() => (
                <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.3 6.9.7-5.1 4.7 1.4 6.8L12 17.8 5.9 21.2l1.4-6.8L2.2 9.7l6.9-.7L12 2Z"/></svg>
              ))}
            </div>
            <blockquote class="mt-4 flex-1 text-[15.5px] leading-relaxed text-ink-700">
              "{q.quote}"
            </blockquote>
            <figcaption class="mt-6 flex items-center gap-3 border-t border-line pt-5">
              <span class="grid size-10 place-items-center rounded-full bg-ink text-[13px] font-bold text-white">
                {q.name.slice(0, 1)}
              </span>
              <span>
                <span class="block text-[14px] font-semibold text-ink">{q.name}</span>
                <span class="block text-[13px] text-ink-400">{q.role}</span>
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
