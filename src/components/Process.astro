---
const steps = [
  {
    n: "01",
    title: "Discovery call",
    desc: "A free 30-minute chat to understand your goals, constraints, and timeline. You leave with clarity even if we don't work together.",
  },
  {
    n: "02",
    title: "Proposal & scope",
    desc: "A clear, fixed plan: what gets built, milestones, timeline, and price. No vague estimates or surprise invoices.",
  },
  {
    n: "03",
    title: "Build in the open",
    desc: "I ship in small increments with regular demos. You see real progress every week and can steer as we go.",
  },
  {
    n: "04",
    title: "Launch & support",
    desc: "We ship to production, hand over clean docs, and I stay available for fixes and the next round of improvements.",
  },
];
---

<section id="process" class="scroll-mt-24 py-24 sm:py-28">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="max-w-2xl">
      <p class="reveal text-[13px] font-semibold uppercase tracking-[0.18em] text-brand">
        How we'll work
      </p>
      <h2 class="reveal mt-3 text-3xl font-extrabold tracking-tight text-ink sm:text-[2.6rem] sm:leading-[1.1]" style="transition-delay:60ms">
        A simple, low-risk process
      </h2>
      <p class="reveal mt-4 text-[17px] leading-relaxed text-ink-500" style="transition-delay:100ms">
        No bloated agency overhead. Just clear communication, weekly progress, and software that works.
      </p>
    </div>

    <div class="mt-14 grid gap-px overflow-hidden rounded-2xl border border-line bg-line sm:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((s, i) => (
          <div class="reveal group relative bg-paper p-7 transition-colors hover:bg-paper-2" style={`transition-delay:${i * 60}ms`}>
            <span class="text-[15px] font-extrabold text-brand">{s.n}</span>
            <h3 class="mt-3 text-lg font-bold tracking-tight text-ink">{s.title}</h3>
            <p class="mt-2 text-[14.5px] leading-relaxed text-ink-500">{s.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
