---
const strengths = [
  "Full-stack: I own the whole product, not just one slice",
  "Plain-English updates — no jargon, no ghosting",
  "Pragmatic engineer who ships, not a perfectionist who stalls",
  "Comfortable with messy legacy code and greenfield alike",
];
---

<section id="about" class="scroll-mt-24 bg-paper-2 py-24 sm:py-28">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-[0.9fr_1.1fr]">
      <!-- Portrait / brand panel -->
      <div class="reveal order-1 lg:order-none">
        <div class="relative mx-auto max-w-sm">
          <div class="aspect-[4/5] overflow-hidden rounded-3xl border border-line bg-gradient-to-br from-ink to-ink-700">
            <div class="flex h-full flex-col items-center justify-center p-8 text-center">
              <span class="grid size-24 place-items-center rounded-2xl bg-brand text-3xl font-extrabold text-white shadow-lg">
                EI
              </span>
              <p class="mt-6 text-xl font-bold text-white">Elmar Ismayil</p>
              <p class="mt-1 text-[14px] text-white/60">Full-Stack Developer</p>
              <div class="mt-6 h-px w-16 bg-white/15"></div>
              <p class="mt-6 text-[13px] leading-relaxed text-white/55">
                Web · Mobile · Desktop<br />Building since 2003
              </p>
            </div>
          </div>
          <div class="absolute -bottom-5 -right-3 rounded-2xl border border-line bg-paper px-5 py-3.5 shadow-lg sm:-right-5">
            <p class="text-[13px] font-medium text-ink-500">Currently</p>
            <p class="text-[15px] font-bold text-ink">Open to new work</p>
          </div>
        </div>
      </div>

      <!-- Copy -->
      <div>
        <p class="reveal text-[13px] font-semibold uppercase tracking-[0.18em] text-brand">
          About
        </p>
        <h2 class="reveal mt-3 text-3xl font-extrabold tracking-tight text-ink sm:text-[2.6rem] sm:leading-[1.1]" style="transition-delay:60ms">
          The reliable partner for your next build
        </h2>
        <div class="reveal mt-5 space-y-4 text-[16.5px] leading-relaxed text-ink-500" style="transition-delay:100ms">
          <p>
            I've spent over 20 years designing, building, and maintaining software across
            web, desktop, and mobile. I've seen what makes projects succeed — and the
            avoidable mistakes that sink them.
          </p>
          <p>
            My approach is simple: understand the real problem, scope it honestly, and
            ship in small, working increments. You get a developer who communicates like a
            partner and treats your budget like it's my own.
          </p>
        </div>

        <ul class="reveal mt-7 grid gap-3 sm:grid-cols-2" style="transition-delay:140ms">
          {
            strengths.map((s) => (
              <li class="flex items-start gap-2.5 text-[14.5px] font-medium text-ink-700">
                <svg class="mt-0.5 shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fd4f00" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {s}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
