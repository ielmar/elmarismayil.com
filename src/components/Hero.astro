---
const stack = [
  "TypeScript",
  "React",
  "Next.js",
  "Node.js",
  "React Native",
  "PHP",
  "PostgreSQL",
  "Cloudflare",
];
---

<section id="top" class="relative overflow-hidden pt-32 sm:pt-40">
  <!-- backdrop -->
  <div class="bg-grid pointer-events-none absolute inset-0 -z-10"></div>
  <div
    class="pointer-events-none absolute -top-24 left-1/2 -z-10 h-72 w-[44rem] max-w-[90vw] -translate-x-1/2 rounded-full bg-brand/20 blur-[110px]"
  >
  </div>

  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <div
        class="reveal inline-flex items-center gap-2 rounded-full border border-line bg-paper px-3.5 py-1.5 text-[13px] font-medium text-ink-500 shadow-sm"
      >
        <span class="relative flex size-2">
          <span class="absolute inline-flex size-full animate-ping rounded-full bg-brand opacity-60"></span>
          <span class="relative inline-flex size-2 rounded-full bg-brand"></span>
        </span>
        Available for new projects — 2025
      </div>

      <h1
        class="reveal mt-6 text-[2.6rem] font-extrabold leading-[1.04] tracking-tight text-ink sm:text-6xl lg:text-[4.25rem]"
        style="transition-delay:60ms"
      >
        I turn ideas into{" "}
        <span class="relative whitespace-nowrap text-brand">
          shipped products
          <svg class="absolute -bottom-2 left-0 w-full" height="12" viewBox="0 0 300 12" fill="none" aria-hidden="true">
            <path d="M2 8C60 3 140 3 298 7" stroke="#fd4f00" stroke-width="3" stroke-linecap="round" opacity="0.5"/>
          </svg>
        </span>
      </h1>

      <p
        class="reveal mx-auto mt-7 max-w-xl text-[17px] leading-relaxed text-ink-500 sm:text-lg"
        style="transition-delay:120ms"
      >
        I'm Elmar — a full-stack developer with{" "}
        <strong class="font-semibold text-ink">20+ years</strong>{" "}
        building fast, reliable web, mobile, and desktop apps. From first sketch to launch,
        I help founders and teams ship software that earns its keep.
      </p>

      <div
        class="reveal mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row"
        style="transition-delay:180ms"
      >
        <a
          href="#contact"
          class="group inline-flex w-full items-center justify-center gap-2 rounded-full bg-brand px-6 py-3.5 text-[15px] font-semibold text-white shadow-lg shadow-brand/25 transition-all hover:bg-brand-600 hover:shadow-brand/40 sm:w-auto"
        >
          Start a project
          <svg class="transition-transform group-hover:translate-x-0.5" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 6l6 6-6 6"/>
          </svg>
        </a>
        <a
          href="#work"
          class="inline-flex w-full items-center justify-center gap-2 rounded-full border border-line bg-paper px-6 py-3.5 text-[15px] font-semibold text-ink transition-colors hover:border-ink/30 sm:w-auto"
        >
          View selected work
        </a>
      </div>

      <p class="reveal mt-5 text-[13px] text-ink-400" style="transition-delay:220ms">
        Free 30-minute scoping call · No obligation · Reply within 24 hours
      </p>
    </div>
  </div>

  <!-- Tech marquee -->
  <div class="reveal mt-16 sm:mt-20" style="transition-delay:260ms">
    <p class="mb-5 text-center text-[12px] font-semibold uppercase tracking-[0.18em] text-ink-400">
      Tools I build with
    </p>
    <div class="marquee">
      <div class="marquee-track gap-3">
        {
          [...stack, ...stack].map((t) => (
            <span class="whitespace-nowrap rounded-full border border-line bg-paper-2 px-4 py-2 text-[14px] font-medium text-ink-700">
              {t}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
