---
const links = [
  { label: "Services", href: "#services" },
  { label: "Work", href: "#work" },
  { label: "Process", href: "#process" },
  { label: "Pricing", href: "#packages" },
  { label: "About", href: "#about" },
  { label: "FAQ", href: "#faq" },
];
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
  data-header
>
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <nav
      class="mt-3 flex items-center justify-between rounded-2xl border border-transparent px-3 py-2.5 transition-all duration-300 sm:px-4"
      data-nav
      aria-label="Primary"
    >
      <a href="#top" class="group flex items-center gap-2.5 pl-1">
        <span
          class="grid size-8 place-items-center rounded-lg bg-ink text-[13px] font-extrabold tracking-tight text-white transition-colors group-hover:bg-brand"
          >EI</span
        >
        <span class="text-[15px] font-semibold tracking-tight">Elmar Ismayil</span>
      </a>

      <div class="hidden items-center gap-7 md:flex">
        {
          links.map((l) => (
            <a
              href={l.href}
              class="text-[14px] font-medium text-ink-500 transition-colors hover:text-ink"
            >
              {l.label}
            </a>
          ))
        }
      </div>

      <div class="flex items-center gap-2">
        <a
          href="#contact"
          class="hidden rounded-full bg-ink px-4 py-2 text-[14px] font-semibold text-white transition-all hover:bg-brand sm:inline-flex"
        >
          Start a project
        </a>
        <button
          type="button"
          class="grid size-10 place-items-center rounded-lg text-ink md:hidden"
          aria-label="Open menu"
          data-menu-btn
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div
    class="pointer-events-none fixed inset-0 z-40 opacity-0 transition-opacity duration-300 md:hidden"
    data-menu-panel
  >
    <div class="absolute inset-0 bg-ink/40 backdrop-blur-sm" data-menu-overlay></div>
    <div
      class="absolute inset-x-4 top-4 translate-y-[-12px] rounded-2xl border border-line bg-paper p-5 opacity-0 shadow-xl transition-all duration-300"
      data-menu-card
    >
      <div class="mb-4 flex items-center justify-between">
        <span class="text-[15px] font-semibold">Menu</span>
        <button type="button" class="grid size-9 place-items-center rounded-lg text-ink-500" aria-label="Close menu" data-menu-close>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M6 6l12 12M18 6L6 18" />
          </svg>
        </button>
      </div>
      <div class="flex flex-col">
        {
          links.map((l) => (
            <a href={l.href} class="border-b border-line py-3 text-[16px] font-medium text-ink" data-menu-link>
              {l.label}
            </a>
          ))
        }
      </div>
      <a
        href="#contact"
        class="mt-4 inline-flex w-full items-center justify-center rounded-full bg-brand px-4 py-3 text-[15px] font-semibold text-white"
        data-menu-link
      >
        Start a project
      </a>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector("[data-nav]");
    const onScroll = () => {
      if (!header) return;
      if (window.scrollY > 8) {
        header.classList.add("border-line", "bg-paper/80", "backdrop-blur-xl", "shadow-[0_1px_0_rgba(0,0,0,0.02)]");
      } else {
        header.classList.remove("border-line", "bg-paper/80", "backdrop-blur-xl", "shadow-[0_1px_0_rgba(0,0,0,0.02)]");
      }
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    const panel = document.querySelector("[data-menu-panel]");
    const card = document.querySelector("[data-menu-card]");
    const open = () => {
      panel?.classList.remove("pointer-events-none", "opacity-0");
      card?.classList.remove("opacity-0", "translate-y-[-12px]");
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      panel?.classList.add("pointer-events-none", "opacity-0");
      card?.classList.add("opacity-0", "translate-y-[-12px]");
      document.body.style.overflow = "";
    };
    document.querySelector("[data-menu-btn]")?.addEventListener("click", open);
    document.querySelector("[data-menu-close]")?.addEventListener("click", close);
    document.querySelector("[data-menu-overlay]")?.addEventListener("click", close);
    document.querySelectorAll("[data-menu-link]").forEach((l) => l.addEventListener("click", close));
  })();
</script>
