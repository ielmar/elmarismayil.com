---
const stats = [
  { value: "15+", label: "Years building software" },
  { value: "40+", label: "Projects shipped" },
  { value: "3", label: "Platforms: web, mobile, desktop" },
  { value: "24h", label: "Typical reply time" },
];
---

<section class="border-y border-line bg-paper-2">
  <div class="mx-auto max-w-6xl px-5 py-12 sm:px-8 sm:py-14">
    <dl class="grid grid-cols-2 gap-x-6 gap-y-9 sm:grid-cols-4">
      {
        stats.map((s, i) => (
          <div class="reveal text-center sm:text-left" style={`transition-delay:${i * 70}ms`}>
            <dt class="text-[34px] font-extrabold tracking-tight text-ink sm:text-[40px]">
              {s.value}
            </dt>
            <dd class="mt-1 text-[13.5px] leading-snug text-ink-500">{s.label}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
