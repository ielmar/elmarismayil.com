---
const services = [
  {
    title: "Web Applications",
    desc: "Production-grade web apps and dashboards built with React, Next.js & TypeScript — fast, accessible, and easy to grow.",
    points: ["SaaS platforms & portals", "Dashboards & internal tools", "API & backend design"],
    icon: "web",
  },
  {
    title: "Mobile Apps",
    desc: "Cross-platform iOS & Android apps from a single codebase, with native polish and a smooth path to the stores.",
    points: ["React Native / Expo", "Offline-first & sync", "App Store & Play launch"],
    icon: "mobile",
  },
  {
    title: "MVP & Product Builds",
    desc: "Have an idea? I take you from concept to a launchable v1 quickly — scoped tight, built right, ready for real users.",
    points: ["Rapid prototyping", "Lean, shippable scope", "Built to scale later"],
    icon: "rocket",
  },
  {
    title: "Rescue & Consulting",
    desc: "Inherited a messy codebase or stalled project? I audit, stabilise, and get delivery moving again — with a clear plan.",
    points: ["Code & architecture audits", "Performance & bug fixes", "Tech strategy"],
    icon: "wrench",
  },
];

const icons: Record<string, string> = {
  web: `<rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18M8 18v2m8-2v2M6 22h12"/>`,
  mobile: `<rect x="6" y="2" width="12" height="20" rx="3"/><path d="M11 18h2"/>`,
  rocket: `<path d="M5 13l-2 5 5-2M9 15l-3-3M14.5 4.5C10 7 8 11 8 16c5 0 9-2 11.5-6.5C21 6 18 3 14.5 4.5Z"/><circle cx="14.5" cy="9.5" r="1.5"/>`,
  wrench: `<path d="M14.5 5.5a4 4 0 0 0-5 5L4 16v4h4l5.5-5.5a4 4 0 0 0 5-5l-2.7 2.7-2.3-.4-.4-2.3 2.6-2.7Z"/>`,
};
---

<section id="services" class="scroll-mt-24 py-24 sm:py-28">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="max-w-2xl">
      <p class="reveal text-[13px] font-semibold uppercase tracking-[0.18em] text-brand">
        Services
      </p>
      <h2 class="reveal mt-3 text-3xl font-extrabold tracking-tight text-ink sm:text-[2.6rem] sm:leading-[1.1]" style="transition-delay:60ms">
        One developer, the whole product
      </h2>
      <p class="reveal mt-4 text-[17px] leading-relaxed text-ink-500" style="transition-delay:100ms">
        Most of my clients don't want to manage a team of vendors. I handle design,
        front end, back end, and launch — so you have a single point of contact and a clear path to shipping.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2">
      {
        services.map((s, i) => (
          <article
            class="reveal group relative overflow-hidden rounded-2xl border border-line bg-paper p-7 transition-all duration-300 hover:-translate-y-1 hover:border-ink/15 hover:shadow-[0_18px_40px_-20px_rgba(12,10,9,0.25)]"
            style={`transition-delay:${(i % 2) * 70}ms`}
          >
            <div class="mb-5 inline-flex size-12 items-center justify-center rounded-xl bg-brand-50 text-brand transition-colors group-hover:bg-brand group-hover:text-white">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon]} />
            </div>
            <h3 class="text-xl font-bold tracking-tight text-ink">{s.title}</h3>
            <p class="mt-2.5 text-[15px] leading-relaxed text-ink-500">{s.desc}</p>
            <ul class="mt-5 space-y-2">
              {s.points.map((p) => (
                <li class="flex items-center gap-2.5 text-[14px] font-medium text-ink-700">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fd4f00" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  {p}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
